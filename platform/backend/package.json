{
  "name": "lingvo-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Lingvo Stage 1 backend (Node.js + TypeScript + Express)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "smoke:release": "node scripts/release-smoke.mjs",
    "verify:release": "npm run typecheck && npm run build && npm run smoke:release",
    "verify:prod-ready": "npm run typecheck && npm run build && npm run preflight:prod"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
